[req]
default_bits       = 2048
prompt             = no
default_md         = sha256
distinguished_name = dn
x509_extensions    = v3_req

[dn]
C  = CN
ST = Beijing
L  = Beijing
O  = MyOrg
CN = localhost

[v3_req]
subjectAltName = @alt_names          # 关键：添加 SAN

[alt_names]
DNS.1 = localhost                    # 域名
IP.1  = 127.0.0.1                   # IP 地址
IP.2  = ::1                         # IPv6
